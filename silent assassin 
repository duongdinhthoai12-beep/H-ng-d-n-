-- NOTIFY
local function NotifyYellow(text)
    local NotifyGui = Instance.new("ScreenGui", CoreGui)

    local Label = Instance.new("TextLabel")
    Label.Parent = NotifyGui
    Label.Size = UDim2.new(0,500,0,50)
    Label.Position = UDim2.new(0.5,-250,0.25,0)
    Label.BackgroundTransparency = 1
    Label.TextColor3 = Color3.fromRGB(255,255,180)
    Label.Text = text
    Label.Font = Enum.Font.GothamBold
    Label.TextSize = 22
    Label.TextStrokeTransparency = 0.3
    Label.TextStrokeColor3 = Color3.new(0,0,0)

    task.spawn(function()
        task.wait(3)
        for i=0,1,0.1 do
            Label.TextTransparency = i
            Label.TextStrokeTransparency = 0.3+(i*0.7)
            task.wait(0.05)
        end
        NotifyGui:Destroy()
    end)
end

