-- SERVICES
local Players = game:GetService("Players")
local RS = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local HttpService = game:GetService("HttpService")

local LP = Players.LocalPlayer
local Camera = workspace.CurrentCamera

-- DELETE OLD GUI
if game.CoreGui:FindFirstChild("STARHub") then
    game.CoreGui.STARHub:Destroy()
end

-- SAVE SYSTEM
local SaveFile = "starhub_settings.json"

local Settings = {
    AutoHit = false,
    ESP = false,
    AutoChest = false
}

if isfile and isfile(SaveFile) then
    Settings = HttpService:JSONDecode(readfile(SaveFile))
end

local function Save()
    if writefile then
        writefile(SaveFile,HttpService:JSONEncode(Settings))
    end
end

-- GUI
local gui = Instance.new("ScreenGui",game.CoreGui)
gui.Name = "STARHub"

local frame = Instance.new("Frame",gui)
frame.Size = UDim2.new(0,220,0,200)
frame.Position = UDim2.new(0.5,-110,0.5,-100)
frame.BackgroundColor3 = Color3.fromRGB(25,25,25)
frame.Active = true
frame.Draggable = true

local title = Instance.new("TextLabel",frame)
title.Size = UDim2.new(1,0,0,30)
title.Text = "⭐ STAR HUB"
title.BackgroundTransparency = 1
title.TextColor3 = Color3.new(1,1,1)

-- STATES
local AutoHit = Settings.AutoHit
local ESPOn = Settings.ESP
local AutoChest = Settings.AutoChest

-- BUTTON FUNCTION
local function MakeButton(text,pos,callback)

    local btn = Instance.new("TextButton",frame)
    btn.Size = UDim2.new(1,-20,0,30)
    btn.Position = pos
    btn.BackgroundColor3 = Color3.fromRGB(40,40,40)
    btn.TextColor3 = Color3.new(1,1,1)
    btn.Text = text

    btn.MouseButton1Click:Connect(callback)

    return btn
end

-- AUTO HIT
local hitBtn = MakeButton(
"Auto Hit : "..(AutoHit and "ON" or "OFF"),
UDim2.new(0,10,0,40),
function()

    AutoHit = not AutoHit
    Settings.AutoHit = AutoHit
    hitBtn.Text = "Auto Hit : "..(AutoHit and "ON" or "OFF")

    Save()

end)

-- AUTO CHEST
local chestBtn = MakeButton(
"Divine Chest : "..(AutoChest and "ON" or "OFF"),
UDim2.new(0,10,0,80),
function()

    AutoChest = not AutoChest
    Settings.AutoChest = AutoChest
    chestBtn.Text = "Divine Chest : "..(AutoChest and "ON" or "OFF")

    Save()

end)

-- ESP
local espBtn = MakeButton(
"ESP : "..(ESPOn and "ON" or "OFF"),
UDim2.new(0,10,0,120),
function()

    ESPOn = not ESPOn
    Settings.ESP = ESPOn
    espBtn.Text = "ESP : "..(ESPOn and "ON" or "OFF")

