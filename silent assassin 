-- AUTO TOOL
local function GetTool()
    local char = LP.Character
    if not char then return nil end

    local tool = char:FindFirstChildOfClass("Tool")

    if not tool then
        local bp = LP.Backpack:FindFirstChildOfClass("Tool")
        if bp then
            bp.Parent = char
            tool = bp
        end
    end

    return tool
end

-- ESP SYSTEM
local ESP = {}

local function createESP(plr)

    local box = Drawing.new("Square")
    box.Thickness = 1
    box.Filled = false
    box.Color = Color3.new(1,1,1)
    box.Visible = false

    local name = Drawing.new("Text")
    name.Size = 13
    name.Center = true
    name.Outline = true
    name.Color = Color3.new(1,1,1)
    name.Visible = false

    ESP[plr] = {box = box, name = name}
end

for _,p in pairs(Players:GetPlayers()) do
    if p ~= LP then
        createESP(p)
    end
end

Players.PlayerAdded:Connect(function(p)
    if p ~= LP then
        createESP(p)
    end
end)

-- TELEPORT DETECT
local lastPos = {}

-- MAIN LOOP
RunService.RenderStepped:Connect(function()

    if AutoHit and LP.Character then

        local myHRP = LP.Character:FindFirstChild("HumanoidRootPart")
        local tool = GetTool()

        if myHRP and tool then

            for _,plr in pairs(Players:GetPlayers()) do
                if plr ~= LP and plr.Character then

                    local enemyHRP = plr.Character:FindFirstChild("HumanoidRootPart")

                    if enemyHRP then

                        local pos = enemyHRP.Position
                        local old = lastPos[plr]

                        if old then
                            local dist = (pos - old).Magnitude

                            -- teleport detect
                            if dist > 40 then
                                task.wait(0.1)
                            end
                        end

                        lastPos[plr] = pos

                        local dir = (pos - myHRP.Position).Unit

                        RS.Events.GameRemoteFunction:InvokeServer(
                            "AttemptWeaponHit",
                            {
                                hitboxOffset = Vector3.new(0,0,-1),
                                hitboxSize = Vector3.new(60,60,60),
                                damage = 123456789,
                                tool = tool,
                                attackCooldown = -0.1
                            },
                            {{
                                enemyModel = plr.Character,
                                origin = myHRP.Position,
                                direction = dir
                            }}
                        )

                    end
                end
            end
        end
    end

    -- AUTO CHEST
    if AutoChest then
        RS.Events.GameRemoteFunction:InvokeServer("AttemptRollGachaChest","Divine")
    end

    -- ESP
    for plr,esp in pairs(ESP) do

        if ESPOn then

            local char = plr.Character
            local hrp = char and char:FindFirstChild("HumanoidRootPart")

            if hrp and LP.Character then

                local myHRP = LP.Character:FindFirstChild("HumanoidRootPart")
                local dist = (hrp.Position - myHRP.Position).Magnitude

                local pos,visible = Camera:WorldToViewportPoint(hrp.Position)

                if visible then

                    esp.box.Size = Vector2.new(40,60)
                    esp.box.Position = Vector2.new(pos.X-20,pos.Y-30)

                    -- đổi màu khi gần
                    if dist < 60 then
                        esp.box.Color = Color3.fromRGB(255,0,0)
                    else
                        esp.box.Color = Color3.fromRGB(255,255,255)
                    end

                    esp.box.Visible = true

                    esp.name.Text = plr.Name
                    esp.name.Position = Vector2.new(pos.X,pos.Y-40)
                    esp.name.Visible = true
                end

            end

        else
            esp.box.Visible = false
            esp.name.Visible = false
        end

    end

end)