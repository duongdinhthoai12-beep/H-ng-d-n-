-- HIDE GUI
local hide = Instance.new("TextButton",gui)
hide.Size = UDim2.new(0,60,0,25)
hide.Position = UDim2.new(0,10,0.5,0)
hide.Text = "HUB"

hide.MouseButton1Click:Connect(function()
    frame.Visible = not frame.Visible
end)

-- ESP SYSTEM
local ESP = {}

local function createESP(plr)

    local box = Drawing.new("Square")
    box.Thickness = 1
    box.Filled = false
    box.Color = Color3.new(1,1,1)
    box.Visible = false

    ESP[plr] = box
end

for _,p in pairs(Players:GetPlayers()) do
    if p ~= LP then
        createESP(p)
    end
end

Players.PlayerAdded:Connect(function(p)
    if p ~= LP then
        createESP(p)
    end
end)

-- TOOL
local function GetTool()

    local char = LP.Character
    if not char then return end

    local tool = char:FindFirstChildOfClass("Tool")

    if not tool then
        local bp = LP.Backpack:FindFirstChildOfClass("Tool")
        if bp then
            bp.Parent = char
            tool = bp
        end
    end

    return tool
end

-- MAIN LOOP
RunService.RenderStepped:Connect(function()

    -- AUTO HIT
    if AutoHit and LP.Character then

        local myHRP = LP.Character:FindFirstChild("HumanoidRootPart")
        local tool = GetTool()

        if myHRP and tool then

            for _,plr in pairs(Players:GetPlayers()) do

                if plr ~= LP and plr.Character then

                    local enemyHRP = plr.Character:FindFirstChild("HumanoidRootPart")

                    if enemyHRP then

                        local dir = (enemyHRP.Position - myHRP.Position).Unit

                        RS.Events.GameRemoteFunction:InvokeServer(
                            "AttemptWeaponHit",
                            {
                                hitboxOffset = Vector3.new(0,0,-1),
                                hitboxSize = Vector3.new(60,60,60),
                                damage = 999999,
                                tool = tool,
                                attackCooldown = -0.1
                            },
                            {{
                                enemyModel = plr.Character,
                                origin = myHRP.Position,
                                direction = dir
                            }}
                        )

                    end
                end
            end
        end
    end

    -- AUTO CHEST
    if AutoChest then
        RS.Events.GameRemoteFunction:InvokeServer(
        "AttemptRollGachaChest",
        "Divine"
        )
    end

    -- ESP
    for plr,box in pairs(ESP) do

        if ESPOn and plr.Character then

            local hrp = plr.Character:FindFirstChild("HumanoidRootPart")

            if hrp then

                local pos,visible = Camera:WorldToViewportPoint(hrp.Position)

                if visible then

                    box.Size = Vector2.new(40,60)
                    box.Position = Vector2.new(pos.X-20,pos.Y-30)
                    box.Visible = true

                end
            end

        else
            box.Visible = false
        end

    end

end)